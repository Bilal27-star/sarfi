# PostgreSQL connection string used by the app at runtime (pooled connections OK)
DATABASE_URL="postgresql://user:password@localhost:5432/sarfi"
# Optional: session-capable connection used only by the Prisma CLI (migrate/seed).
# Required in production when DATABASE_URL points at a transaction-mode pooler
# (e.g. Supabase's pooler on port 6543), which doesn't support the advisory
# locks `prisma migrate deploy` needs. Falls back to DATABASE_URL if unset.
DIRECT_URL="postgresql://user:password@localhost:5432/sarfi"
# Random 32+ char secret used to sign/derive session material
SESSION_SECRET="generate-a-long-random-string"
